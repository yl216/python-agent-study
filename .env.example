# Required: your DeepSeek API key. Do not commit the real .env file.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: DeepSeek OpenAI-compatible endpoint.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: model name.
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: response randomness, from 0.0 to 2.0.
DEEPSEEK_TEMPERATURE=0.3

# Optional: how many recent conversation turns to keep, from 1 to 20.
MAX_HISTORY_TURNS=5
